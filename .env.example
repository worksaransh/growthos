# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string
ENVIRONMENT=production
BACKEND_URL=https://your-backend.railway.app
FRONTEND_URL=https://your-app.vercel.app
NEXT_PUBLIC_BACKEND_URL=https://your-backend.railway.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Shopify ─────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_REDIRECT_URI=https://your-backend.railway.app/api/v1/oauth/shopify/callback
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret

# ─── Meta Ads ────────────────────────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://your-backend.railway.app/api/v1/oauth/meta/callback

# ─── Google ──────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend.railway.app/api/v1/oauth/google/callback
GOOGLE_DEVELOPER_TOKEN=your_google_developer_token

# ─── WhatsApp ────────────────────────────────────────────────────────────────
WHATSAPP_API_URL=https://api.interakt.ai/v1
WHATSAPP_API_KEY=your_interakt_api_key

# ─── Payments ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Shipping ────────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=your_email@domain.com
SHIPROCKET_PASSWORD=your_shiprocket_password

# ─── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key

# ─── Meta CAPI ───────────────────────────────────────────────────────────────
META_PIXEL_ID=your_pixel_id_here
META_CAPI_ACCESS_TOKEN=your_capi_token_here
META_CAPI_TEST_CODE=TEST12345
